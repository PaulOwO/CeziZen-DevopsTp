# Modèle de configuration — copier en `.env` puis renseigner des valeurs.
#   cp .env.example .env
# Le fichier .env réel n'est PAS versionné (voir .gitignore).

# ── Base de données PostgreSQL (service `db` du docker-compose) ──
POSTGRES_USER=cesizen
POSTGRES_PASSWORD=change-me
POSTGRES_DB=cesizen

# ── Application Nuxt ──
# Secret de chiffrement des cookies de session (nuxt-auth-utils).
# DOIT faire au moins 32 caractères. Générer une valeur aléatoire en prod.
NUXT_SESSION_PASSWORD=change-me-please-use-32-chars-minimum
